{
  "expo": {
    "name": "TradeVidhi",
    "slug": "TradeVidhi",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tradevidhi",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.anonymous.TradeVidhi"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.TradeVidhi"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "@clerk/expo",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
